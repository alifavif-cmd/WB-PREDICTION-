name: Inject Header WONGBAGUS (Python)

on:
  workflow_dispatch:

jobs:
  inject:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v3

      - name: Inject header.js pakai Python
        run: |
          python3 << 'EOF'
          import os

          files = [
              "Rumus_Otomatis.html",
              "Rumus_Lengkap.html",
              "Scanner_Rumus.html",
              "Smart_Paito.html",
              "DataTogel.html",
              "Paito_Warna.html",
          ]

          tag = '<script src="header.js"></script>'

          for f in files:
              if not os.path.exists(f):
                  print(f"Skip {f} (tidak ada)")
                  continue
              with open(f, "r", encoding="utf-8", errors="ignore") as fh:
                  content = fh.read()
              if tag in content:
                  print(f"Skip {f} (sudah ada)")
                  continue
              content = content.replace("</body>", f"{tag}\n</body>", 1)
              with open(f, "w", encoding="utf-8") as fh:
                  fh.write(content)
              print(f"OK {f}")
          EOF

      - name: Commit
        run: |
          git config user.name "github-actions"
          git config user.email "actions@github.com"
          git add *.html
          git diff --staged --quiet || git commit -m "Inject header WONGBAGUS (Python safe)"
          git push
